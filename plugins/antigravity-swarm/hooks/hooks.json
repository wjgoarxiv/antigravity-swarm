{
  "antigravity-swarm": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/asw-hook.mjs\"",
        "timeout": 10,
        "statusMessage": "ASW: checking aliases and workflow hooks"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(write_to_file|multi_replace_file_content|write_file|replace_file_content|run_command|apply_patch|Write|Edit|MultiEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "node \"${PLUGIN_ROOT}/scripts/asw-lsp-check.mjs\"",
            "timeout": 60,
            "statusMessage": "ASW: checking diagnostics"
          }
        ]
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "node \"${PLUGIN_ROOT}/scripts/asw-stop-check.mjs\"",
        "timeout": 10,
        "statusMessage": "ASW: checking continuation"
      }
    ]
  }
}
